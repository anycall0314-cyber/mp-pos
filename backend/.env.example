# ─────────────────────────────────────────────────────────
# 後端正式環境變數範本
# 在 Mac mini 上複製成 .env 並填入實際值:
#   cp .env.example .env
#   vim .env
# 啟動時:
#   export $(grep -v '^#' .env | xargs) && gunicorn ...
# 或在 launchd plist 裡用 EnvironmentVariables 帶
# ─────────────────────────────────────────────────────────

# Django 設定 module(prod 用這個)
DJANGO_SETTINGS_MODULE=config.settings.prod

# Django SECRET_KEY:用 `python -c "import secrets;print(secrets.token_urlsafe(60))"` 產一個
DJANGO_SECRET_KEY=請改成隨機 60 字元字串

# 是否 debug(prod 永遠 false)
DJANGO_DEBUG=false

# 允許的 hosts:Cloudflare Tunnel 對外網域 + 本機
# 例:DJANGO_ALLOWED_HOSTS=mppos.example.com,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=請改成你的網域,localhost,127.0.0.1

# CORS 允許的前端 origin(因為前後端同 host 由 Django 一起 serve,
# 通常用不到。如果未來前端拆出去獨立部署再填)
CORS_ALLOWED_ORIGINS=

# PostgreSQL 連線字串
# 格式:postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://mppos:請改成強密碼@localhost:5432/mppos

# 預設 tenant id(MVP 用,登入系統上線後就不會用到)
DEFAULT_TENANT_ID=1
